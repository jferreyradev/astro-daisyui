---
const { title, paragraph } = Astro.props;
---

<section class="md:col-span-9">
  <div class="rounded-xl border bg-white p-6">
    <h1 class="text-2xl font-bold">{title}</h1>
    <p class="mt-2 text-gray-600">{paragraph}</p>

    <div class="mt-6 grid gap-4 ">
      <slot></slot>
    </div>
  </div>
</section>
